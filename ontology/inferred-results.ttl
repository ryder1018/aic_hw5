                                                           <https://hcis.io/ontology/aicapstone/2026/hasPoseFrame> "world/object_plate" ;
                                                           rdfs:comment "The plate instance for the cutlery-arrangement task. It is not grasped; it acts as the fixed spatial reference around which knife and fork are arranged."@en ;
                                                           rdfs:label "plate 01"@en ;
