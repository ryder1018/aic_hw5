@prefix : <http://www.semanticweb.org/ma097/ontologies/2026/5/untitled-ontology-2#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/ma097/ontologies/2026/5/untitled-ontology-2> .

<http://www.semanticweb.org/ma097/ontologies/2026/5/untitled-ontology-2> rdf:type owl:Ontology ;
                                                                          <http://purl.org/dc/terms/created> "2026-05-22"^^xsd:date ,
                                                                                                             "2026-05-30"^^xsd:date ;
                                                                          <http://purl.org/dc/terms/creator> <https://hcis.io/ontology/aicapstone/2026/ccyont> ,
                                                                                                             <https://hcis.io/ontology/aicapstone/2026/group15/group15> ;
                                                                          <http://purl.org/dc/terms/description> "This ontology defines Group 15 environment instances for the three baseline course tasks and models their object types, task roles, and manipulation affordances to support OWL-based graspability inference."@en ,
                                                                                                                 "This ontology defines a compact course vocabulary for representing physical task objects, task roles, manipulation affordances, grounding identifiers, and inferable graspability in the AI Capstone 2026 Physical AI project."@en ;
                                                                          <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                                                          <http://purl.org/dc/terms/title> "AI Capstone 2026 Course Ontology"@en ,
                                                                                                           "AI Capstone 2026 Group 15 Toy Block Collection Ontology"@en ;
                                                                          <http://purl.org/vocab/vann/preferredNamespacePrefix> "cap" ,
                                                                                                                                "g15" ;
                                                                          <http://purl.org/vocab/vann/preferredNamespaceUri> "https://hcis.io/ontology/aicapstone/2026/" ,
                                                                                                                             "https://hcis.io/ontology/aicapstone/2026/group15/" ;
                                                                          rdfs:comment "A reduced educational ontology profile for semantic and affordance grounding of graspable objects in the AI Capstone 2026 course project."@en ,
                                                                                       "The Group 15 ontology for grounding baseline environment objects across all three course tasks: cup stacking, cutlery arrangement, and toy block collection."@en ;
                                                                          rdfs:label "AI Capstone 2026 Course Ontology"@en ,
                                                                                     "AI Capstone 2026 Group 15 Ontology"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/created
<http://purl.org/dc/terms/created> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
<http://www.w3.org/2004/02/skos/core#definition> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#scopeNote
<http://www.w3.org/2004/02/skos/core#scopeNote> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/mbox
<http://xmlns.com/foaf/0.1/mbox> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/member
<http://xmlns.com/foaf/0.1/member> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/name
<http://xmlns.com/foaf/0.1/name> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://hcis.io/ontology/aicapstone/2026/canBeManipulatedBy
<https://hcis.io/ontology/aicapstone/2026/canBeManipulatedBy> rdf:type owl:ObjectProperty ;
                                                              rdfs:domain <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ;
                                                              rdfs:range <https://hcis.io/ontology/aicapstone/2026/EndEffector> ;
                                                              rdfs:comment "Relates a physical object to an end effector capable of manipulating it."@en ;
                                                              rdfs:label "can be manipulated by"@en .


###  https://hcis.io/ontology/aicapstone/2026/hasAffordance
<https://hcis.io/ontology/aicapstone/2026/hasAffordance> rdf:type owl:ObjectProperty ;
                                                         rdfs:domain <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ;
                                                         rdfs:range <https://hcis.io/ontology/aicapstone/2026/Affordance> ;
                                                         rdfs:comment "Relates a physical object to an affordance associated with that object in the task context."@en ;
                                                         rdfs:label "has affordance"@en .


###  https://hcis.io/ontology/aicapstone/2026/hasReferenceObject
<https://hcis.io/ontology/aicapstone/2026/hasReferenceObject> rdf:type owl:ObjectProperty ;
                                                              rdfs:domain <https://hcis.io/ontology/aicapstone/2026/Task> ;
                                                              rdfs:range <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ;
                                                              rdfs:comment "Relates a task to a physical object used as a spatial or semantic reference."@en ;
                                                              rdfs:label "has reference object"@en .


###  https://hcis.io/ontology/aicapstone/2026/hasTargetObject
<https://hcis.io/ontology/aicapstone/2026/hasTargetObject> rdf:type owl:ObjectProperty ;
                                                           rdfs:domain <https://hcis.io/ontology/aicapstone/2026/Task> ;
                                                           rdfs:range <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ;
                                                           rdfs:comment "Relates a task to a physical object that is directly acted upon in that task."@en ;
                                                           rdfs:label "has target object"@en .


###  https://hcis.io/ontology/aicapstone/2026/hasTaskRole
<https://hcis.io/ontology/aicapstone/2026/hasTaskRole> rdf:type owl:ObjectProperty ;
                                                       rdfs:domain <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ;
                                                       rdfs:range <https://hcis.io/ontology/aicapstone/2026/TaskRole> ;
                                                       rdfs:comment "Relates a physical object to the role it plays in a task."@en ;
                                                       rdfs:label "has task role"@en .


#################################################################
#    Data properties
#################################################################

###  https://hcis.io/ontology/aicapstone/2026/hasApproxWidth
<https://hcis.io/ontology/aicapstone/2026/hasApproxWidth> rdf:type owl:DatatypeProperty ;
                                                          rdfs:domain <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ;
                                                          rdfs:range xsd:decimal ;
                                                          rdfs:comment "Records an approximate object width in metres, useful for checking whether an object fits within a gripper's opening range."@en ;
                                                          rdfs:label "has approximate width"@en .


###  https://hcis.io/ontology/aicapstone/2026/hasColor
<https://hcis.io/ontology/aicapstone/2026/hasColor> rdf:type owl:DatatypeProperty ;
                                                    rdfs:domain <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ;
                                                    rdfs:range xsd:string ;
                                                    rdfs:comment "Records the perceived or assigned color of a physical object."@en ;
                                                    rdfs:label "has color"@en .


###  https://hcis.io/ontology/aicapstone/2026/hasObjectLabel
<https://hcis.io/ontology/aicapstone/2026/hasObjectLabel> rdf:type owl:DatatypeProperty ;
                                                          rdfs:domain <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ;
                                                          rdfs:range xsd:string ;
                                                          rdfs:comment "Records the object label used by perception, simulation, or task documentation."@en ;
                                                          rdfs:label "has object label"@en .


###  https://hcis.io/ontology/aicapstone/2026/hasPoseFrame
<https://hcis.io/ontology/aicapstone/2026/hasPoseFrame> rdf:type owl:DatatypeProperty ;
                                                        rdfs:domain <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ;
                                                        rdfs:range xsd:string ;
                                                        rdfs:comment "Links an ontology individual to a coordinate frame or pose-frame identifier used in perception, reconstruction, or simulation."@en ;
                                                        rdfs:label "has pose frame"@en .


#################################################################
#    Classes
#################################################################

###  http://xmlns.com/foaf/0.1/Group
<http://xmlns.com/foaf/0.1/Group> rdf:type owl:Class .


###  http://xmlns.com/foaf/0.1/Person
<http://xmlns.com/foaf/0.1/Person> rdf:type owl:Class .


###  https://hcis.io/ontology/aicapstone/2026/Affordance
<https://hcis.io/ontology/aicapstone/2026/Affordance> rdf:type owl:Class ;
                                                      rdfs:comment "An action possibility associated with an object in relation to a robot capability and task context."@en ;
                                                      rdfs:label "affordance"@en .


###  https://hcis.io/ontology/aicapstone/2026/Basket
<https://hcis.io/ontology/aicapstone/2026/Basket> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ,
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty <https://hcis.io/ontology/aicapstone/2026/hasAffordance> ;
                                                                    owl:someValuesFrom <https://hcis.io/ontology/aicapstone/2026/ContainmentAffordance>
                                                                  ] ;
                                                  rdfs:comment "A container target used to receive toy blocks in the toy-block-collection task. Its primary affordance is containment; it is not a direct grasp target in this task."@en ;
                                                  rdfs:label "basket"@en .


###  https://hcis.io/ontology/aicapstone/2026/CollectableObject
<https://hcis.io/ontology/aicapstone/2026/CollectableObject> rdf:type owl:Class ;
                                                             rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/TaskRole> ;
                                                             rdfs:comment "A task role for an object that should be collected into another object or location."@en ;
                                                             rdfs:label "collectable object"@en .


###  https://hcis.io/ontology/aicapstone/2026/ContainerTarget
<https://hcis.io/ontology/aicapstone/2026/ContainerTarget> rdf:type owl:Class ;
                                                           rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/TaskRole> ;
                                                           rdfs:comment "A task role for an object that receives or contains other objects."@en ;
                                                           rdfs:label "container target"@en .


###  https://hcis.io/ontology/aicapstone/2026/ContainmentAffordance
<https://hcis.io/ontology/aicapstone/2026/ContainmentAffordance> rdf:type owl:Class ;
                                                                 rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/Affordance> ;
                                                                 rdfs:comment "An affordance by which an object can contain or receive other objects."@en ;
                                                                 rdfs:label "containment affordance"@en .


###  https://hcis.io/ontology/aicapstone/2026/Cup
<https://hcis.io/ontology/aicapstone/2026/Cup> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/GraspableObject> ,
                                                               <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <https://hcis.io/ontology/aicapstone/2026/hasAffordance> ;
                                                                 owl:someValuesFrom <https://hcis.io/ontology/aicapstone/2026/GraspingAffordance>
                                                               ] ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <https://hcis.io/ontology/aicapstone/2026/hasAffordance> ;
                                                                 owl:someValuesFrom <https://hcis.io/ontology/aicapstone/2026/StackabilityAffordance>
                                                               ] ;
                                               rdfs:comment "A container-like object used in the cup-stacking task."@en ;
                                               rdfs:label "cup"@en .


###  https://hcis.io/ontology/aicapstone/2026/EndEffector
<https://hcis.io/ontology/aicapstone/2026/EndEffector> rdf:type owl:Class ;
                                                       rdfs:comment "A robot component used to physically interact with objects, such as a gripper."@en ;
                                                       rdfs:label "end effector"@en .


###  https://hcis.io/ontology/aicapstone/2026/Fork
<https://hcis.io/ontology/aicapstone/2026/Fork> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/GraspableObject> ,
                                                                <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ,
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <https://hcis.io/ontology/aicapstone/2026/hasAffordance> ;
                                                                  owl:someValuesFrom <https://hcis.io/ontology/aicapstone/2026/GraspingAffordance>
                                                                ] ;
                                                rdfs:comment "A cutlery object to be placed in the cutlery-arrangement task."@en ;
                                                rdfs:label "fork"@en .


###  https://hcis.io/ontology/aicapstone/2026/GraspableObject
<https://hcis.io/ontology/aicapstone/2026/GraspableObject> rdf:type owl:Class ;
                                                           owl:equivalentClass [ owl:intersectionOf ( <https://hcis.io/ontology/aicapstone/2026/PhysicalObject>
                                                                                                      [ rdf:type owl:Restriction ;
                                                                                                        owl:onProperty <https://hcis.io/ontology/aicapstone/2026/hasAffordance> ;
                                                                                                        owl:someValuesFrom <https://hcis.io/ontology/aicapstone/2026/GraspingAffordance>
                                                                                                      ]
                                                                                                    ) ;
                                                                                 rdf:type owl:Class
                                                                               ] ;
                                                           rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ;
                                                           rdfs:comment "A physical object inferred to afford grasping by a robot end effector in the task context. Membership is derived by an OWL reasoner, not manually asserted."@en ;
                                                           rdfs:label "graspable object"@en .


###  https://hcis.io/ontology/aicapstone/2026/GraspingAffordance
<https://hcis.io/ontology/aicapstone/2026/GraspingAffordance> rdf:type owl:Class ;
                                                              rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/Affordance> ;
                                                              rdfs:comment "An affordance by which an object may be grasped, held, lifted, or repositioned by a robot gripper."@en ;
                                                              rdfs:label "grasping affordance"@en .


###  https://hcis.io/ontology/aicapstone/2026/Knife
<https://hcis.io/ontology/aicapstone/2026/Knife> rdf:type owl:Class ;
                                                 rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/GraspableObject> ,
                                                                 <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ,
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty <https://hcis.io/ontology/aicapstone/2026/hasAffordance> ;
                                                                   owl:someValuesFrom <https://hcis.io/ontology/aicapstone/2026/GraspingAffordance>
                                                                 ] ;
                                                 rdfs:comment "A cutlery object to be placed in the cutlery-arrangement task."@en ;
                                                 rdfs:label "knife"@en .


###  https://hcis.io/ontology/aicapstone/2026/ManipulationTask
<https://hcis.io/ontology/aicapstone/2026/ManipulationTask> rdf:type owl:Class ;
                                                            rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/Task> ;
                                                            rdfs:comment "A task in which a robot changes the pose, state, or arrangement of physical objects."@en ;
                                                            rdfs:label "manipulation task"@en .


###  https://hcis.io/ontology/aicapstone/2026/PhysicalObject
<https://hcis.io/ontology/aicapstone/2026/PhysicalObject> rdf:type owl:Class ;
                                                          rdfs:comment "A material object in the task environment that may be perceived, manipulated, used as a reference object, or assigned a task role."@en ;
                                                          rdfs:label "physical object"@en .


###  https://hcis.io/ontology/aicapstone/2026/Plate
<https://hcis.io/ontology/aicapstone/2026/Plate> rdf:type owl:Class ;
                                                 rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ,
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty <https://hcis.io/ontology/aicapstone/2026/hasAffordance> ;
                                                                   owl:someValuesFrom <https://hcis.io/ontology/aicapstone/2026/SupportAffordance>
                                                                 ] ;
                                                 rdfs:comment "A reference object used for arranging cutlery in the cutlery-arrangement task. It provides a support surface but is not a direct manipulation target in this task."@en ;
                                                 rdfs:label "plate"@en .


###  https://hcis.io/ontology/aicapstone/2026/ReferenceObject
<https://hcis.io/ontology/aicapstone/2026/ReferenceObject> rdf:type owl:Class ;
                                                           rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/TaskRole> ;
                                                           rdfs:comment "A task role for an object used as a spatial or semantic reference for arranging other objects."@en ;
                                                           rdfs:label "reference object"@en .


###  https://hcis.io/ontology/aicapstone/2026/StackabilityAffordance
<https://hcis.io/ontology/aicapstone/2026/StackabilityAffordance> rdf:type owl:Class ;
                                                                  rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/Affordance> ;
                                                                  rdfs:comment "An affordance by which an object can participate in a stacking relation with another object."@en ;
                                                                  rdfs:label "stackability affordance"@en .


###  https://hcis.io/ontology/aicapstone/2026/SupportAffordance
<https://hcis.io/ontology/aicapstone/2026/SupportAffordance> rdf:type owl:Class ;
                                                             rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/Affordance> ;
                                                             rdfs:comment "An affordance by which an object can support the placement or arrangement of other objects."@en ;
                                                             rdfs:label "support affordance"@en .


###  https://hcis.io/ontology/aicapstone/2026/TargetObject
<https://hcis.io/ontology/aicapstone/2026/TargetObject> rdf:type owl:Class ;
                                                        rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/TaskRole> ;
                                                        rdfs:comment "A task role for an object that is directly acted upon or manipulated."@en ;
                                                        rdfs:label "target object"@en .


###  https://hcis.io/ontology/aicapstone/2026/Task
<https://hcis.io/ontology/aicapstone/2026/Task> rdf:type owl:Class ;
                                                rdfs:comment "A goal-directed activity to be performed or evaluated in the course project."@en ;
                                                rdfs:label "task"@en .


###  https://hcis.io/ontology/aicapstone/2026/TaskRole
<https://hcis.io/ontology/aicapstone/2026/TaskRole> rdf:type owl:Class ;
                                                    rdfs:comment "A role that an object plays within a task."@en ;
                                                    rdfs:label "task role"@en .


###  https://hcis.io/ontology/aicapstone/2026/ToyBlock
<https://hcis.io/ontology/aicapstone/2026/ToyBlock> rdf:type owl:Class ;
                                                    rdfs:subClassOf <https://hcis.io/ontology/aicapstone/2026/GraspableObject> ,
                                                                    <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ,
                                                                    [ rdf:type owl:Restriction ;
                                                                      owl:onProperty <https://hcis.io/ontology/aicapstone/2026/hasAffordance> ;
                                                                      owl:someValuesFrom <https://hcis.io/ontology/aicapstone/2026/GraspingAffordance>
                                                                    ] ;
                                                    rdfs:comment "A small object to be collected into the basket in the toy-block-collection task."@en ;
                                                    rdfs:label "toy block"@en .


#################################################################
#    Individuals
#################################################################

###  https://hcis.io/ontology/aicapstone/2026/ccyont
<https://hcis.io/ontology/aicapstone/2026/ccyont> rdf:type owl:NamedIndividual ,
                                                           <http://xmlns.com/foaf/0.1/Person> ;
                                                  <http://xmlns.com/foaf/0.1/mbox> <mailto:ccy@hptp.org> ;
                                                  <http://xmlns.com/foaf/0.1/name> "Chun-yien Chang"@en .


###  https://hcis.io/ontology/aicapstone/2026/group15/basket01
<https://hcis.io/ontology/aicapstone/2026/group15/basket01> rdf:type owl:NamedIndividual ,
                                                                     <https://hcis.io/ontology/aicapstone/2026/Basket> ,
                                                                     <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ;
                                                            <https://hcis.io/ontology/aicapstone/2026/hasAffordance> <https://hcis.io/ontology/aicapstone/2026/group15/containmentAffordance> ;
                                                            <https://hcis.io/ontology/aicapstone/2026/hasTaskRole> <https://hcis.io/ontology/aicapstone/2026/group15/containerTargetRole> ;
                                                            <https://hcis.io/ontology/aicapstone/2026/hasColor> "white" ;
                                                            <https://hcis.io/ontology/aicapstone/2026/hasObjectLabel> "basket" ;
                                                            <https://hcis.io/ontology/aicapstone/2026/hasPoseFrame> "world/object_basket" ;
                                                            rdfs:comment "The white basket that receives toy blocks. It is the container target of the Group 15 task and is not itself grasped by the robot."@en ;
                                                            rdfs:label "basket 01"@en ;
                                                            <http://www.w3.org/2004/02/skos/core#definition> "A white woven basket that serves as the deposit destination for all toy blocks. The robot does not grasp the basket; it uses the basket's interior as the target region for block deposition."@en ;
                                                            <http://www.w3.org/2004/02/skos/core#scopeNote> "Basket is modelled with ContainmentAffordance only, not GraspingAffordance, because its task role is to receive objects rather than to be grasped. It is therefore not inferred as cap:GraspableObject."@en .


###  https://hcis.io/ontology/aicapstone/2026/group15/block01
<https://hcis.io/ontology/aicapstone/2026/group15/block01> rdf:type owl:NamedIndividual ,
                                                                    <https://hcis.io/ontology/aicapstone/2026/GraspableObject> ,
                                                                    <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ,
                                                                    <https://hcis.io/ontology/aicapstone/2026/ToyBlock> ;
                                                           <https://hcis.io/ontology/aicapstone/2026/hasAffordance> <https://hcis.io/ontology/aicapstone/2026/group15/graspingAffordance> ;
                                                           <https://hcis.io/ontology/aicapstone/2026/hasTaskRole> <https://hcis.io/ontology/aicapstone/2026/group15/collectableObjectRole> ;
                                                           <https://hcis.io/ontology/aicapstone/2026/hasColor> "blue" ;
                                                           <https://hcis.io/ontology/aicapstone/2026/hasObjectLabel> "toy_block_01" ;
                                                           <https://hcis.io/ontology/aicapstone/2026/hasPoseFrame> "world/object_toy_block_01" ;
                                                           rdfs:comment "A blue toy block to be collected into the basket. It is a direct grasp target in the Group 15 task."@en ;
                                                           rdfs:label "toy block 01"@en ;
                                                           <http://www.w3.org/2004/02/skos/core#definition> "A small blue-coloured cubic toy block. The robot grasps its top face, lifts it, and deposits it into the basket."@en .


###  https://hcis.io/ontology/aicapstone/2026/group15/block02
<https://hcis.io/ontology/aicapstone/2026/group15/block02> rdf:type owl:NamedIndividual ,
                                                                    <https://hcis.io/ontology/aicapstone/2026/GraspableObject> ,
                                                                    <https://hcis.io/ontology/aicapstone/2026/PhysicalObject> ,
                                                                    <https://hcis.io/ontology/aicapstone/2026/ToyBlock> ;
                                                           <https://hcis.io/ontology/aicapstone/2026/hasAffordance> <https://hcis.io/ontology/aicapstone/2026/group15/graspingAffordance> ;
                                                           <https://hcis.io/ontology/aicapstone/2026/hasTaskRole> <https://hcis.io/ontology/aicapstone/2026/group15/collectableObjectRole> ;
                                                           <https://hcis.io/ontology/aicapstone/2026/hasColor> "green" ;
